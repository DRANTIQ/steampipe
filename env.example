# Copy to .env and fill from user_input.md

# Database (normalize postgres:// to postgresql://)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Job queue
REDIS_URL=redis://default:password@host:port

# S3 snapshots (optional: use local path for dev)
S3_BUCKET=steampipe-data-storage
S3_REGION=us-east-1
USE_LOCAL_STORAGE=false
LOCAL_STORAGE_PATH=./local/snapshots
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Steampipe (worker only)
STEAMPIPE_PATH=/usr/local/bin/steampipe
STEAMPIPE_INSTALL_DIR=
STEAMPIPE_CONFIG_DIR=/tmp/steampipe
# Port for worker's Steampipe service (default 9194; avoids conflict with default 9193)
STEAMPIPE_DATABASE_PORT=9194
# Set true to disable TLS for local Steampipe DB (avoids "certificate signed by unknown authority")
STEAMPIPE_DATABASE_INSECURE=false
# Seconds to wait after Steampipe service is listening before running query (plugin init / GetCallerIdentity retries; default 45)
# STEAMPIPE_CONNECTION_INIT_WAIT_SECONDS=45

# Worker
MAX_CONCURRENT_EXECUTIONS=3
# Debug: set to 1 to log full AWS creds and run STS GetCallerIdentity before passing to Steampipe (insecure)
# DEBUG_AWS_CREDENTIALS=0

# Scheduler
SCHEDULER_ENABLED=true

# Executions: chunk size for trigger-tenant and scheduler (default 200)
# BULK_QUERY_IDS_MAX=200

# Auth
JWT_SECRET_KEY=dev-secret
API_AUTH_REQUIRED=false
RATE_LIMIT_PER_MINUTE=60
